generator client {
  provider = "prisma-client-js"
}

datasource db {
  // Supabase is PostgreSQL-compatible, so Prisma must use the postgresql provider.
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                      String                   @id @default(cuid())
  name                    String
  email                   String                   @unique
  passwordHash            String
  emailVerifiedAt         DateTime?
  languagePreferences     String[]                 @default([])
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  playlists               Playlist[]
  likedSongs              LikedSong[]
}

model Playlist {
  id          String         @id @default(cuid())
  userId      String
  name        String
  description String?
  source      PlaylistSource @default(USER)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  songs       PlaylistSong[]

  @@index([userId])
  @@index([userId, source])
}

enum PlaylistSource {
  USER
  ONLINE
}

model PlaylistSong {
  id           String   @id @default(cuid())
  playlistId   String
  videoId      String
  title        String
  channelTitle String
  thumbnail    String
  publishedAt  DateTime?
  addedAt      DateTime @default(now())
  playlist     Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)

  @@unique([playlistId, videoId])
  @@index([playlistId])
}

model LikedSong {
  id           String    @id @default(cuid())
  userId       String
  videoId      String
  title        String
  channelTitle String
  thumbnail    String
  publishedAt  DateTime?
  createdAt    DateTime  @default(now())
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, videoId])
  @@index([userId])
}
